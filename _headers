/*
  # Security headers — applied to every response
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.anthropic.com; frame-ancestors 'none'

# Favicon + manifest — cache forever (immutable per deploy)
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
/manifest.json
  Cache-Control: public, max-age=86400

# OG default image
/og-image.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# Per-topic OG images — regenerated on content change, cache 7 days
/v2/og/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Search index — regenerated on content change, cache 1 day
/search.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# Chat widget — cache 1 day
/chat-widget.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# v2 sub-pages (non-HTML static assets inside v2)
/v2/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

# HTML pages — always serve latest
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/v2/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Cloudflare Pages Functions — never cache
/api/*
  Cache-Control: no-store
